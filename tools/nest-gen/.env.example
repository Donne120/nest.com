# ── LLM (NVIDIA free tier) ────────────────────────────────────────────────
LLM_PROVIDER=nvidia
LLM_CALL_INTERVAL=3
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_IMAGE_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TTS (free Microsoft neural voices) ───────────────────────────────────
TTS_ENGINE=edge
EDGE_VOICE=en-US-JennyNeural
# Other great free voices:
# en-US-GuyNeural       (male, professional)
# en-GB-SoniaNeural     (British female)
# en-AU-NatashaNeural   (Australian female)

# ── Visual ───────────────────────────────────────────────────────────────
SLIDE_THEME=dark

# ── Nest platform ────────────────────────────────────────────────────────
NEST_API_URL=http://localhost:8000
NEST_TOKEN=your_jwt_token_here
# Get your token: log in to Nest → open browser DevTools → Application → localStorage → nest_token
